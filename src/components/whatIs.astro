---
// Tech section component with futuristic background
---

<section class="relative flex items-center justify-center overflow-hidden section-operating-bg">

	<div class=" w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 ">
		<div class="grid  h-screen grid-cols-1 lg:grid-cols-2 items-center gap-12">
			<!-- Left: Copy -->
			<div class="text-center lg:text-left">
			  <h3 class="hero-heading text-5xl sm:text-6xl md:text-7xl lg:text-7xl xl:text-8xl font-bold text-white mb-8 leading-tight tracking-tight">
				Invertir, comprar casa o terreno
				<br>
				<span class="italic font-light opacity-95 text-white/90"> facil y seguro a un click</span>
			  </h3>
			  <div class="mt-10">
				<button class="btn-primary px-12 py-6 rounded-2xl font-bold text-xl hover:shadow-2xl transition-all duration-300 transform hover:scale-105 shadow-2xl">
				  Comenzar ahora →
				</button>
			  </div>
			</div>
			<!-- Right: App image -->
			<div class="flex justify-center lg:justify-end">
			  <img src="/MobileApp.png" alt="Interfaz de SUBAXA para explorar remates y propiedades en Costa Rica" class="w-[90%] max-w-md lg:max-w-lg drop-shadow-2xl" loading="lazy" decoding="async" />
			</div>
		  </div>
		  <br/>
	  
	</div>
</section>
