---
type FaqItem = { question: string; answer: string };

interface Props {
	items: readonly FaqItem[];
}

const { items } = Astro.props;
---

<section
	id="preguntas-frecuentes"
	class="relative py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-black border-t border-white/10"
	aria-labelledby="faq-heading"
>
	<div class="max-w-3xl mx-auto">
		<h2
			id="faq-heading"
			class="text-3xl sm:text-4xl font-bold text-white mb-4 text-center"
		>
			Preguntas frecuentes
		</h2>
		<p class="text-white/70 text-center mb-12 max-w-xl mx-auto text-sm sm:text-base">
			Respuestas breves sobre SUBAXA y los remates inmobiliarios en Costa Rica.
		</p>
		<dl class="space-y-6">
			{
				items.map((item) => (
					<div class="rounded-2xl border border-white/15 bg-white/5 px-6 py-5">
						<dt class="text-lg font-semibold text-white mb-2">{item.question}</dt>
						<dd class="text-white/80 text-sm sm:text-base leading-relaxed">
							{item.answer}
						</dd>
					</div>
				))
			}
		</dl>
	</div>
</section>
