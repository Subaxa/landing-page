---
import '../styles/global.css';

export interface FaqItem {
	question: string;
	answer: string;
}

// SEO Props interface
export interface Props {
	title?: string;
	description?: string;
	image?: string;
	/** Texto para og:image:alt y contexto de accesibilidad */
	imageAlt?: string;
	url?: string;
	type?: string;
	/** Nodos extra en @graph (p. ej. BreadcrumbList, ItemList) */
	jsonLdExtra?: Record<string, unknown>[];
	faqItems?: FaqItem[];
}

const site = Astro.site ?? new URL('https://subaxa.com');

const {
	title = 'SUBAXA - Inversión Inteligente en Bienes Raíces en Costa Rica',
	description = 'Plataforma líder para invertir, comprar casa o terreno en Costa Rica. Acceso exclusivo a propiedades en remate con tecnología de IA y asesoría experta. Encuentra oportunidades únicas en bienes raíces.',
	image = '/og-default.png',
	imageAlt = 'SUBAXA — plataforma de remates inmobiliarios con IA en Costa Rica',
	url = 'https://subaxa.com',
	type = 'website',
	jsonLdExtra = [],
	faqItems = [],
} = Astro.props;

const pageUrl = url;
const siteOrigin = new URL(pageUrl).origin;
const imageUrl = new URL(image, site).href;

const businessId = `${siteOrigin}/#business`;
const websiteId = `${siteOrigin}/#website`;

const graph: Record<string, unknown>[] = [
	{
		'@type': 'WebSite',
		'@id': websiteId,
		url: siteOrigin,
		name: 'SUBAXA',
		publisher: { '@id': businessId },
		inLanguage: 'es-CR',
	},
	{
		'@type': 'RealEstateAgent',
		'@id': businessId,
		name: 'SUBAXA',
		description,
		url: siteOrigin,
		logo: imageUrl,
		image: imageUrl,
		address: {
			'@type': 'PostalAddress',
			addressLocality: 'San Carlos',
			addressRegion: 'Alajuela',
			addressCountry: 'CR',
		},
		contactPoint: {
			'@type': 'ContactPoint',
			telephone: '+506 8821-1348',
			contactType: 'customer service',
			email: 'info@subaxa.com',
		},
		sameAs: [
			'https://www.linkedin.com/company/subaxa',
			'https://www.facebook.com/subaxaai',
		],
		areaServed: {
			'@type': 'Country',
			name: 'Costa Rica',
		},
		serviceType: 'Real Estate Investment Platform',
		priceRange: '$$',
	},
	{
		'@type': 'WebPage',
		'@id': `${pageUrl}#webpage`,
		url: pageUrl,
		name: title,
		description,
		isPartOf: { '@id': websiteId },
		about: { '@id': businessId },
		inLanguage: 'es-CR',
	},
];

if (faqItems.length > 0) {
	graph.push({
		'@type': 'FAQPage',
		'@id': `${pageUrl}#faq`,
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: item.answer,
			},
		})),
	});
}

if (jsonLdExtra.length > 0) {
	graph.push(...jsonLdExtra);
}

const structuredData = {
	'@context': 'https://schema.org',
	'@graph': graph,
};
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="author" content="SUBAXA" />
		<meta name="robots" content="index, follow" />
		<meta name="language" content="Spanish" />

		<!-- Canonical URL -->
		<link rel="canonical" href={url} />

		<!-- Favicon and Icons -->
		<link rel="icon" type="image/ico" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon_io/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon_io/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon_io/favicon-16x16.png" />
		<link rel="manifest" href="/manifest.json" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={imageAlt} />
		<meta property="og:site_name" content="SUBAXA" />
		<meta property="og:locale" content="es_CR" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={url} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<meta name="twitter:image:alt" content={imageAlt} />
		<meta name="twitter:creator" content="@subaxa" />
		<meta name="twitter:site" content="@subaxa" />

		<!-- Additional SEO Meta Tags -->
		<meta name="theme-color" content="#2979FF" />
		<meta name="msapplication-TileColor" content="#2979FF" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="apple-mobile-web-app-title" content="SUBAXA" />

		<!-- Structured Data / JSON-LD -->
		<script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

		<!-- Google tag (gtag.js) -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-X8174C8BGW"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-X8174C8BGW');
		</script>

		<!-- Preconnect to external domains for performance -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<!-- Generator -->
		<meta name="generator" content={Astro.generator} />
		<!-- Security Headers -->
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		<meta http-equiv="X-Frame-Options" content="DENY" />
		<meta http-equiv="X-XSS-Protection" content="1; mode=block" />
		<meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
	</head>
	<body class="min-h-screen bg-black text-white antialiased">
		<slot />
	</body>
</html>
